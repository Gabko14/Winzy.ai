.DS_Store

# bv (beads viewer) local config and caches
.bv/

# br (beads_rust) - SQLite database (JSONL is tracked, DB is not)
.beads/*.db
.beads/*.db-shm
.beads/*.db-wal
.beads/*.lock

# Migration artifacts
.beads-go-backup/
.beads/backup/

# Beadspace generated data (pipeline regenerates from .beads/issues.jsonl)
.beadspace/*.json

# Environment files (keep .env.example tracked)
.env

# IDE / editor
.idea/
.vs/

# Claude Code (local settings, not .mcp.json)
.claude/

# br history snapshots
.beads/.br_history/

# Node.js
node_modules/

# .NET
**/bin/
**/obj/
*.user
*.suo

# Test results
test-results/

# Playwright
e2e/.auth/
e2e/playwright-report/
e2e/test-results/
e2e/blob-report/
.playwright-mcp/

frontend/coverage
coverage.json
