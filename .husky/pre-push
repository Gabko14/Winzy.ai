#!/usr/bin/env sh
# Pre-push: thorough checks — typecheck, build, test
# Skip with: git push --no-verify

REMOTE="$1"
URL="$2"

# Determine the range of commits being pushed
while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  if [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ]; then
    # Deleting a branch, nothing to check
    continue
  fi

  if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
    # New branch — compare against main
    RANGE="origin/main...$LOCAL_SHA"
  else
    RANGE="$REMOTE_SHA...$LOCAL_SHA"
  fi

  CHANGED_FILES=$(git diff --name-only "$RANGE" 2>/dev/null || git diff --name-only "origin/main...HEAD")

  # --- Frontend checks ---
  if echo "$CHANGED_FILES" | grep -q '^frontend/'; then
    echo "Frontend changes detected — running typecheck and tests..."
    (cd frontend && npx tsc --noEmit) || exit 1
    (cd frontend && npm test -- --ci --passWithNoTests) || exit 1
  fi

  # --- Backend checks: gofmt, vet, build, test ---
  if echo "$CHANGED_FILES" | grep -q '^backend/'; then
    echo "Backend changes detected — running Go gates..."
    FMT_OUT=$(cd backend && gofmt -l .) || exit 1
    if [ -n "$FMT_OUT" ]; then
      echo "Not gofmt-formatted:"
      echo "$FMT_OUT"
      exit 1
    fi
    (cd backend && go vet -tags=integration ./...) || exit 1
    (cd backend && go build ./...) || exit 1
    # Integration tests need Postgres (docker compose up -d winzy-db → :5439).
    if [ -z "$TEST_DATABASE_URL" ]; then
      TEST_DATABASE_URL="postgres://winzy:winzy@localhost:5439/winzy?sslmode=disable"
      export TEST_DATABASE_URL
    fi
    (cd backend && go test -tags=integration ./...) || exit 1
  fi
done

echo "All pre-push checks passed."
